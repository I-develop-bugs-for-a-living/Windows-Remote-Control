{
  "name": "bridge",
  "private": true,
  "version": "0.1.0",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prepare:pwa-assets": "node scripts/prepare-pwa-assets.mjs",
    "package:exe": "npm run build && npm run prepare:pwa-assets && pkg . --targets node18-win-x64 --output ../../release/RemoteControlBridge.exe && node scripts/copy-native-addon.mjs"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@remote-control/shared": "*",
    "express": "^4.21.2",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.5",
    "pkg": "^5.8.1",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2"
  },
  "pkg": {
    "assets": [
      "pwa-dist/**/*"
    ],
    "scripts": "dist/index.js"
  }
}